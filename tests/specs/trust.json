[
  {
    "name": "/trust without args shows usage",
    "steps": [
      {
        "send": { "text": "/trust" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /trust @username"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/trust with user confirms trust",
    "steps": [
      {
        "send": { "text": "/trust @moderator" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "User trusted. They're now exempt from verification."
            }
          }
        ]
      }
    ]
  }
]
