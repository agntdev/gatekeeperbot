[
  {
    "name": "/untrust without args shows usage",
    "steps": [
      {
        "send": { "text": "/untrust" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /untrust @username"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/untrust with user confirms untrust",
    "steps": [
      {
        "send": { "text": "/untrust @moderator" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Trust removed. They'll need to verify like everyone else."
            }
          }
        ]
      }
    ]
  }
]
