[
  {
    "name": "/stats shows overview",
    "steps": [
      {
        "send": { "text": "/stats" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Stats for the last 24h:\n\nJoins: 0\nModeration actions: none"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "stats button shows overview",
    "steps": [
      {
        "send": { "callback": "stats:show" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Stats for the last 24h:\n\nJoins: 0\nModeration actions: none"
            }
          }
        ]
      }
    ]
  }
]
