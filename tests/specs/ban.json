[
  {
    "name": "/ban without args shows usage",
    "steps": [
      {
        "send": { "text": "/ban" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /ban @username reason"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/ban with reason confirms ban",
    "steps": [
      {
        "send": { "text": "/ban @troll persistent trolling" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "User banned. Reason: persistent trolling"
            }
          }
        ]
      }
    ]
  }
]
