[
  {
    "name": "/warn without args shows usage",
    "steps": [
      {
        "send": { "text": "/warn" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /warn @username reason"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/warn with reason logs and confirms",
    "steps": [
      {
        "send": { "text": "/warn @user spam" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "User warned. Reason: spam"
            }
          }
        ]
      }
    ]
  }
]
