[
  {
    "name": "/mute without args shows usage",
    "steps": [
      {
        "send": { "text": "/mute" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /mute @username duration reason"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/mute with args confirms mute",
    "steps": [
      {
        "send": { "text": "/mute @flooder 1h flooding chat" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "User muted for 1h. Reason: flooding chat"
            }
          }
        ]
      }
    ]
  }
]
