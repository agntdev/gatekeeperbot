[
  {
    "name": "/kick without args shows usage",
    "steps": [
      {
        "send": { "text": "/kick" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Usage: /kick @username reason"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/kick with reason confirms kick",
    "steps": [
      {
        "send": { "text": "/kick @disruptor disruptive behavior" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "User kicked. Reason: disruptive behavior"
            }
          }
        ]
      }
    ]
  }
]
